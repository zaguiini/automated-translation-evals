msgstr "Permite frete grátis"

#. Value for the limit usage to X items row in Coupon Usage Restrictions screen
#. when no limit is set
msgctxt "All Qualifying"
msgid "All Qualifying"
msgstr "Todos os itens elegíveis"

#. Exception rule for a coupon. Reads like: All Products · Excl. 2 Products
msgctxt "All Products · Excl. %1$@"
msgid "All Products · Excl. %1$@"
msgstr "Todos os produtos, exceto %1$@"

#. The plural limit of time for each user to apply a coupon, reads like: 10
#. uses per user
msgctxt "%1$d uses per user"
msgid "%1$d uses per user"
msgstr "%1$d usos por usuário"

#. The singular limit of time for each user to apply a coupon, reads like: 1
#. use per user
msgctxt "%1$d use per user"
msgid "%1$d use per user"
msgstr "%1$d uso por usuário"

#. Summary line for a coupon, with the discounted amount and number of products
#. and categories that the coupon is limited to. Reads like: '10% off · all
#. products' or '$15 off · 2 Product 1 Category'
msgctxt "%1$@ off · %2$@"
msgid "%1$@ off · %2$@"
msgstr "%1$@ de desconto em %2$@"

#. The description on the placeholder overlay on the coupon list screen when
#. coupons are disabled for the store.
msgctxt "You currently have Coupons disabled for this store. Enable coupons to get started."
msgid "You currently have Coupons disabled for this store. Enable coupons to get started."
msgstr "No momento, a opção de cupons está desativada para esta loja. Ative-a para começar."

#. Title of a button linking to the Automattic Work With Us web page
msgctxt "Work with us"
msgid "Work with us"
msgstr "Trabalhe conosco"

#. Subject line for when sharing the app with others through mail or any other
#. activity types that support contains a subject field.
msgctxt "WooCommerce Mobile App - Run your store from anywhere"
msgid "WooCommerce Mobile App - Run your store from anywhere"
msgstr "Aplicativo móvel do WooCommerce: gerencie sua loja de onde estiver"

#. Title of a button linking to the app's website
msgctxt "Website"
msgid "Website"
msgstr "Site"

#. Message displayed in the error prompt when loading total discounted amount
#. in Coupon Details screen fails
msgctxt "We encountered a problem loading analytics"
msgid "We encountered a problem loading analytics"
msgstr "Ocorreu um problema ao carregar a análise"

#. Title that appears on top of the of bulk price setting screen
msgctxt "Update Regular Price"
msgid "Update Regular Price"
msgstr "Atualizar preço regular"

#. Unable to retrieve variations for bulk update screen
msgctxt "Unable to retrieve variations"
msgid "Unable to retrieve variations"
msgstr "Não é possível recuperar variações"

#. Notice displayed when syncing the list of products fails
msgctxt "There was an error syncing products"
msgid "There was an error syncing products"
msgstr "Ocorreu um erro ao sincronizar produtos"

#. Notice displayed when syncing the list of product variations fails
msgctxt "There was an error syncing product variations"
msgid "There was an error syncing product variations"
msgstr "Ocorreu um erro ao sincronizar variações de produtos"

#. Notice displayed when searching the list of products fails
msgctxt "There was an error searching products"
msgid "There was an error searching products"
msgstr "Ocorreu um erro ao pesquisar produtos"

#. Message in the footer of bulk price setting screen (plurar).
msgctxt "The price will be updated for %d variations."
msgid "The price will be updated for %d variations."
msgstr "O preço de %d variações será alterado."

#. Message in the footer of bulk price setting screen (singular).
msgctxt "The price will be updated for %d variation."
msgid "The price will be updated for %d variation."
msgstr "O preço de %d variação será alterado."

#. Error message shown when a refund could not be canceled (likely because it
#. had already completed)
msgctxt "Sorry, this refund could not be canceled."
msgid "Sorry, this refund could not be canceled."
msgstr "Não foi possível cancelar este reembolso"

#. Title for button allowing users to share information about the app with
#. friends, such as via Messages
msgctxt "Share with Friends"
msgid "Share with Friends"
msgstr "Compartilhe com seus amigos"

#. Title of button that allows the user to rate the app in the App Store
msgctxt "Rate us"
msgid "Rate us"
msgstr "Classifique-nos"

#. Accessibility hint for selecting a product in an order form
msgctxt "Opens product detail."
msgid "Opens product detail."
msgstr "Abre os detalhes do produto."

#. Accessibility hint for excluding a variable product in the Exclude Products
#. screen
#.    Accessibility hint for selecting a variable product in the Add Product
#. screen
#.    Accessibility hint for selecting a variable product in the Select
#. Products screen
msgctxt "Opens list of product variations."
msgid "Opens list of product variations."
msgstr "Abre a lista de variações do produto."

#. Message on the detail view of the Orders tab before any order is selected
msgctxt "No order selected"
msgid "No order selected"
msgstr "Nenhum pedido selecionado"

#. Message format on enable analytics screen for support. The %@ placeholder is
#. a URL with more information.
msgctxt "Need some help? %1$@"
msgid "Need some help? %1$@"
msgstr "Precisa de ajuda? %1$@"

#. Title of a button linking to a list of legal documents like privacy
#. policy,terms of service, etc
msgctxt "Legal and more"
msgid "Legal and more"
msgstr "Jurídico e mais"

#. Subtitle for button displaying the Automattic Work With Us web page,
#. indicating that Automattic employees can work from anywhere in the world
msgctxt "Join from anywhere"
msgid "Join from anywhere"
msgstr "Participe de qualquer lugar"

#. Message on enable analytics screen to notify that the module is disabled for
#. the store
msgctxt "It looks like you have analytics disabled."
msgid "It looks like you have analytics disabled."
msgstr "Parece que a análise está desativada."

#. Title of a button linking to the app's Instagram profile
msgctxt "Instagram"
msgid "Instagram"
msgstr "Instagram"

#. Text used when sharing a link to the app with a friend.
msgctxt "Hey! Here is a link to download the WooCommerce app. I'm really enjoying it and thought you might too."
msgid "Hey! Here is a link to download the WooCommerce app. I'm really enjoying it and thought you might too."
msgstr "Olá! Este é um link para fazer download do aplicativo do WooCommerce. Eu estou gostando muito de usá-lo e acho que talvez você goste também."

#. Error message when enabling analytics fails
msgctxt "Error enabling analytics. Please try again."
msgid "Error enabling analytics. Please try again."
msgstr "Erro ao ativar a análise. Tente novamente."

#. Title for the enable analytics screen
msgctxt "Enable WooCommerce Analytics to see your stats"
msgid "Enable WooCommerce Analytics to see your stats"
msgstr "Ativar o WooCommerce Analytics para ver estatísticas"

#. Description about WooCommerce Analytics on the enable analytics screen
msgctxt "Enable WooCommerce Analytics to see missing stats for your store."
msgid "Enable WooCommerce Analytics to see missing stats for your store."
msgstr "Ative o WooCommerce Analytics para ver as estatísticas que faltam da sua loja."

#. The action button on the placeholder overlay on the coupon list screen when
#. coupons are disabled for the store.
msgctxt "Enable Coupons"
msgid "Enable Coupons"
msgstr "Ativar cupons"

#. Action title to enable Analytics for a store
msgctxt "Enable analytics"
msgid "Enable analytics"
msgstr "Ativar análise"

#. Accessibility label for the button to edit customer note on the New Order
#. screen
msgctxt "Edit customer note"
msgid "Edit customer note"
msgstr "Editar anotação do cliente"

#. Title for dismiss the action when dragging the screen down.
msgctxt "Dismiss Order"
msgid "Dismiss Order"
msgstr "Ignorar pedido"

#. Title text of the section that shows the Order customer note when creating a
#. new order
msgctxt "Customer Note"
msgid "Customer Note"
msgstr "Anotação do cliente"

#. Message in the footer of bulk price setting screen, when products have
#. different price values.
#.    Message in the footer of bulk price setting screen, when variations have
#. different price values.
msgctxt "Current prices are mixed."
msgid "Current prices are mixed."
msgstr "Os preços atuais estão misturados."

#. Message in the footer of bulk price setting screen, when none of the
#. products have price value.
#.    Message in the footer of bulk price setting screen, when none of the
#. variations have price value.
msgctxt "Current price is not set."
msgid "Current price is not set."
msgstr "O preço atual não está definido."

#. Message in the footer of bulk price setting screen with the current price,
#. when it is the same for all products
#.    Message in the footer of bulk price setting screen with the current
#. price, when it is the same for all variations
msgctxt "Current price is %@."
msgid "Current price is %@."
msgstr "O preço atual é %@."

#. Action button to contact support on enable analytics screen
#.    The title of the button to contact support in the Error Loading Data
#. banner
msgctxt "Contact support"
msgid "Contact support"
msgstr "Contate o suporte"

#. Title of a button linking to the app's blog
msgctxt "Blog"
msgid "Blog"
msgstr "Blog"

#. Title of a button linking to the Automattic website
msgctxt "Automattic family"
msgid "Automattic family"
msgstr "Família Automattic"

#. Message when enabling analytics succeeds
msgctxt "Analytics enabled successfully."
msgid "Analytics enabled successfully."
msgstr "Análise ativada com sucesso."

#. Accessibility hint for selecting a variation in a list of product variations
msgctxt "Adds variation to order."
msgid "Adds variation to order."
msgstr "Adiciona variação ao pedido."

#. Accessibility hint for selecting a product in the Add Product screen
msgctxt "Adds product to order."
msgid "Adds product to order."
msgstr "Adiciona produto ao pedido."

#. Title for the error screen when In-Person Payments is not supported because
#. we don't know the name of the country
#. The hyphen in "In‑Person" is a non-breaking hyphen (U+2011).
#. If your translation of that term also happens to contains a hyphen, please
#. be sure to use the non-breaking hyphen character for it
msgctxt "We don’t support In‑Person Payments with Stripe in your country"
msgid "We don’t support In‑Person Payments with Stripe in your country"
msgstr "Não aceitamos pagamentos presenciais com Stripe em seu país"

#. Title for the error screen when In-Person Payments is not supported in a
#. specific country
#. The hyphen in "In‑Person" is a non-breaking hyphen (U+2011).
#. If your translation of that term also happens to contains a hyphen, please
#. be sure to use the non-breaking hyphen character for it
msgctxt "We don’t support In‑Person Payments with Stripe in %1$@"
msgid "We don’t support In‑Person Payments with Stripe in %1$@"
msgstr "Não aceitamos pagamentos presenciais com Stripe em %1$@"

#. Error message when the card reader battery level is too low to safely
#. perform a software update.
msgctxt "Unable to update card reader software - the reader battery is too low."
msgid "Unable to update card reader software - the reader battery is too low."
msgstr "Não foi possível atualizar o software do leitor de cartão porque a bateria está muito fraca."

#. Error message when Bluetooth scan times out during reader discovery.
msgctxt "Unable to search for card readers - Bluetooth timed out - please try again."
msgid "Unable to search for card readers - Bluetooth timed out - please try again."
msgstr "Não foi possível pesquisar leitores de cartão porque o Bluetooth atingiu o tempo limite. Tente novamente."

#. Error message when Bluetooth Low Energy is not supported on the user device.
msgctxt "Unable to search for card readers - Bluetooth Low Energy is not supported on this device - please use a different device."
msgid "Unable to search for card readers - Bluetooth Low Energy is not supported on this device - please use a different device."
msgstr "Não foi possível pesquisar leitores de cartão porque o Bluetooth Low Energy não é compatível com este dispositivo. Use outro dispositivo."

#. Error message when the card reader is unable to read a swiped card.
msgctxt "Unable to read swiped card - please try swiping again."
msgid "Unable to read swiped card - please try swiping again."
msgstr "Não foi possível ler o cartão. Passe-o novamente."

#. Error message when the card reader is unable to read any chip on the
#. inserted card.
msgctxt "Unable to read inserted card - please try removing and inserting card again."
msgid "Unable to read inserted card - please try removing and inserting card again."
msgstr "Não foi possível ler o cartão. Insira-o novamente."

#. Error message when the card reader times out while reading a card.
msgctxt "Unable to read card - the system timed out - please try again."
msgid "Unable to read card - the system timed out - please try again."
msgstr "Não foi possível ler o cartão. O sistema atingiu o tempo limite. Tente novamente."

#. Error message when the payment intent is invalid.
msgctxt "Unable to process payment due to invalid data - please try again."
msgid "Unable to process payment due to invalid data - please try again."
msgstr "Não foi possível processar o pagamento devido a dados inválidos. Tente novamente."

#. Error message when the application is so out of date that the backend
#. refuses to work with it.
msgctxt "Unable to perform software request - please update this application and try again."
msgid "Unable to perform software request - please update this application and try again."
msgstr "Não foi possível realizar solicitação ao software. Atualize o aplicativo e tente novamente."

#. Error message when the card reader cannot be used to perform the requested
#. task.
msgctxt "Unable to perform request with the connected reader - unsupported feature - please try again with another reader."
msgid "Unable to perform request with the connected reader - unsupported feature - please try again with another reader."
msgstr "Não foi possível realizar solicitação ao leitor conectado. O recurso não é compatível. Tente novamente com outro leitor."

#. Notice displayed when data cannot be synced for new order
msgctxt "Unable to load taxes for order"
msgid "Unable to load taxes for order"
msgstr "Não foi possível carregar impostos do pedido"

#. Error message the card reader battery level is too low to connect to the
#. phone or tablet.
msgctxt "Unable to connect to reader - the reader has a critically low battery - charge the reader and try again."
msgid "Unable to connect to reader - the reader has a critically low battery - charge the reader and try again."
msgstr "Não foi possível conectar ao leitor porque ele está com a bateria muito baixa. Carregue-o e tente novamente."

#. Error message when a card reader is already connected and we were not
#. expecting one.
msgctxt "Unable to connect to reader - another reader is already connected."
msgid "Unable to connect to reader - another reader is already connected."
msgstr "Não foi possível conectar ao leitor porque outro leitor já está conectado."

#. Error message when attempting to connect to a card reader which is already
#. in use.
msgctxt "Unable to connect to card reader - the card reader is already in use."
msgid "Unable to connect to card reader - the card reader is already in use."
msgstr "Não foi possível conectar ao leitor de cartão porque ele já está em uso."

#. Error message when communication with the card reader is disrupted.
msgctxt "Unable to communicate with reader - please try again."
msgid "Unable to communicate with reader - please try again."
msgstr "Não foi possível estabelecer comunicação com o leitor. Tente novamente."

#. Error message when location services is not enabled for this application.
msgctxt "Unable to access Location Services - please enable Location Services and try again."
msgid "Unable to access Location Services - please enable Location Services and try again."
msgstr "Não foi possível acessar os serviços de localização. Ative-os e tente novamente."

#. Error message when Bluetooth is not enabled or available.
msgctxt "Unable to access Bluetooth - please enable Bluetooth and try again."
msgid "Unable to access Bluetooth - please enable Bluetooth and try again."
msgstr "Não foi possível acessar o Bluetooth. Ative-o e tente novamente."

#. Message when a card is declined due to a potentially temporary problem.
msgctxt "Trying again may succeed, or try another means of payment."
msgid "Trying again may succeed, or try another means of payment."
msgstr "Tente novamente ou experimente outro meio de pagamento"

#. Message from the in-person payment card reader prompting user to retry a
#. payment using a different method, e.g. swipe, tap, insert
msgctxt "Try Another Read Method"
msgid "Try Another Read Method"
msgstr "Tente outro método de leitura"

#. Message when a lost or stolen card is presented for payment. Do NOT disclose
#. fraud.
msgctxt "Try another means of payment."
msgid "Try another means of payment."
msgstr "Tente outro meio de pagamento"

#. Message from the in-person payment card reader prompting user to retry a
#. payment using a different card
msgctxt "Try Another Card"
msgid "Try Another Card"
msgstr "Tente outro cartão"

#. Message when a card requires a PIN code and we have no means of entering
#. such a code.
msgctxt "This card requires a PIN code and thus cannot be processed. Try another means of payment."
msgid "This card requires a PIN code and thus cannot be processed. Try another means of payment."
msgstr "Este cartão requer um código PIN e, por isso, não pode ser processado. Tente outro meio de pagamento"

msgctxt "This app needs permission to access the Camera to capture new media, please change the privacy settings if you wish to allow this."
msgid "This app needs permission to access the Camera to capture new media, please change the privacy settings if you wish to allow this."
msgstr "Este aplicativo precisa de permissão para acessar a câmera e capturar novas mídias. Altere as configurações de privacidade para permitir isto."

#. A general error message shown to the user when there was an API
#. communication failure.
msgctxt "There was a problem communicating with the site."
msgid "There was a problem communicating with the site."
msgstr "Ocorreu um problema na comunicação com o site."

#. Message when the presented card postal code doesn't match the order postal
#. code.
msgctxt "The transaction postal code and card postal code do not match. Try another means of payment."
msgid "The transaction postal code and card postal code do not match. Try another means of payment."
msgstr "O código postal da transação e o código postal do cartão não são o mesmo. Tente outro meio de pagamento"

#. Error message when the card reader service experiences an unexpected
#. software error.
msgctxt "The system experienced an unexpected software error."
msgid "The system experienced an unexpected software error."
msgstr "Ocorreu um erro de software inesperado."

#. Error message when the system cancels a command.
msgctxt "The system canceled the command unexpectedly - please try again."
msgid "The system canceled the command unexpectedly - please try again."
msgstr "O sistema cancelou seu comando inesperadamente. Tente novamente."

#. Error message when there is an issue with the store postal code preventing
#. an action (e.g. reader connection.)
msgctxt "The store postal code is invalid or missing, please update it before continuing."
msgid "The store postal code is invalid or missing, please update it before continuing."
msgstr "O código postal da loja é inválido ou está ausente. Atualize-o antes de prosseguir."

#. Error message when there is an issue with the store address preventing an
#. action (e.g. reader connection.)
msgctxt "The store address is incomplete or missing, please update it before continuing."
msgid "The store address is incomplete or missing, please update it before continuing."
msgstr "O endereço da loja está incompleto ou ausente. Atualize-o antes de prosseguir."

#. A failure reason for when the response couldn't be serialized.
msgctxt "The serialization of the response failed."
msgid "The serialization of the response failed."
msgstr "Falha na serialização da resposta."

#. A failure reason for when the request couldn't be serialized.
msgctxt "The serialization of the request failed."
msgid "The serialization of the request failed."
msgstr "Falha na serialização da solicitação."

#. Error message when a request times out.
msgctxt "The request timed out - please try again."
msgid "The request timed out - please try again."
msgstr "O tempo da solicitação atingiu o limite. Tente novamente."

#. Error message when the payment can not be processed (i.e. order amount is
#. below the minimum amount allowed.)
msgctxt "The payment can not be processed by the payment processor."
msgid "The payment can not be processed by the payment processor."
msgstr "O pagamento não pode ser processado pelo processador de pagamento."

#. Message when the presented card does not allow the purchase amount.
msgctxt "The payment amount is not allowed for the card presented. Try another means of payment."
msgid "The payment amount is not allowed for the card presented. Try another means of payment."
msgstr "O valor do pagamento não é permitido para o cartão informado. Tente outro meio de pagamento."

#. Error message when the card processor declines the payment.
msgctxt "The card was declined by the payment processor - please try another means of payment."
msgid "The card was declined by the payment processor - please try another means of payment."
msgstr "O cartão foi recusado pelo processador. Tente outro meio de pagamento."

#. Error message when the card reader itself declines the card.
msgctxt "The card was declined by the card reader - please try another means of payment"
msgid "The card was declined by the card reader - please try another means of payment"
msgstr "O cartão foi recusado pelo leitor. Tente outro meio de pagamento."

#. Error message when the card reader software update is interrupted.
msgctxt "The card reader software update was interrupted before it could complete - please try again."
msgid "The card reader software update was interrupted before it could complete - please try again."
msgstr "A atualização do software do leitor de cartão foi interrompida antes da conclusão. Tente novamente."

#. Error message when the card reader software update fails unexpectedly.
msgctxt "The card reader software update failed unexpectedly - please try again."
msgid "The card reader software update failed unexpectedly - please try again."
msgstr "A atualização do software do leitor de cartão falhou inesperadamente. Tente novamente."

#. Error message when the card reader software update fails due to a problem
#. with the update server.
msgctxt "The card reader software update failed due to a problem with the update server - please try again."
msgid "The card reader software update failed due to a problem with the update server - please try again."
msgstr "A atualização do software do leitor de cartão falhou devido à um problema com o servidor de atualização. Tente novamente."

#. Error message when the card reader software update fails due to a
#. communication error.
msgctxt "The card reader software update failed due to a communication error - please try again."
msgid "The card reader software update failed due to a communication error - please try again."
msgstr "A atualização do software do leitor de cartão falhou devido à um problema de comunicação. Tente novamente."

#. Error message when the card reader software is too far out of date to
#. process payments.
msgctxt "The card reader software is out-of-date - please update the card reader software before attempting to process payments"
msgid "The card reader software is out-of-date - please update the card reader software before attempting to process payments"
msgstr "O software do leitor de cartão está desatualizado. Atualize-o antes de tentar processar pagamentos."

#. Error message when the card reader session has timed out.
msgctxt "The card reader session has expired - please disconnect and reconnect the card reader and then try again."
msgid "The card reader session has expired - please disconnect and reconnect the card reader and then try again."
msgstr "A sessão do leitor de cartão expirou. Desconecte e reconecte-o e tente novamente."

#. Error message when the card reader is incompatible with the application.
msgctxt "The card reader is not compatible with this application - please try updating the application or using a different reader."
msgid "The card reader is not compatible with this application - please try updating the application or using a different reader."
msgstr "O leitor de cartão não é compatível com este aplicativo. Atualize o aplicativo ou use um leitor diferente."

#. Error message when the card reader is busy executing another command.
msgctxt "The card reader is busy executing another command - please try again."
msgid "The card reader is busy executing another command - please try again."
msgstr "O leitor de cartão está ocupado executando outro comando. Tente novamente."

#. Message when payment is declined for a non specific reason.
msgctxt "The card or card account is invalid. Try another means of payment."
msgid "The card or card account is invalid. Try another means of payment."
msgstr "O cartão ou a conta do cartão são inválidos. Tente outro meio de pagamento"

#. Message when the presented card is past its expiration date.
msgctxt "The card has expired. Try another means of payment."
msgid "The card has expired. Try another means of payment."
msgstr "O cartão expirou. Tente outro meio de pagamento"

#. Message when the card presented does not allow this type of purchase.
msgctxt "The card does not support this type of purchase. Try another means of payment."
msgid "The card does not support this type of purchase. Try another means of payment."
msgstr "O cartão não é compatível com este tipo de compra. Tente outro meio de pagamento"

#. Message when the card presented does not support the order currency.
msgctxt "The card does not support this currency. Try another means of payment."
msgid "The card does not support this currency. Try another means of payment."
msgstr "O cartão não é compatível com esta moeda. Tente outro meio de pagamento"

#. Error message when the card reader loses its Bluetooth connection to the
#. card reader.
msgctxt "The Bluetooth connection to the card reader disconnected unexpectedly."
msgid "The Bluetooth connection to the card reader disconnected unexpectedly."
msgstr "A conexão Bluetooth com o leitor de cartão caiu inesperadamente"

#. Confirmation message in Inbox Notes after responding to a survey.
msgctxt "Thank you for your feedback!"
msgid "Thank you for your feedback!"
msgstr "Obrigado pelo seu feedback!"

#. Navigation bar title for the Payment Methods screens. %1$@ is a placeholder
#. for the total amount to collect
#.    Text of the button that creates a simple payment order. %1$@ is a
#. placeholder for the total amount to collect
msgctxt "Take Payment (%1$@)"
msgid "Take Payment (%1$@)"
msgstr "Receber pagamento (%1$@)"

#. Message when attempting to pay for a live transaction with a test card.
msgctxt "System test cards are not permitted for payment. Try another means of payment."
msgid "System test cards are not permitted for payment. Try another means of payment."
msgstr "Cartões de teste do sistema não são permitidos para pagamentos. Tente outro meio de pagamento"

#. Message from the in-person payment card reader prompting user to swipe their
#. card
msgctxt "Swipe Card"
msgid "Swipe Card"
msgstr "Passe o cartão"

#. Title of 'Summary' section in the receipt. %1$@ is the order number, e.g.
#. 4920
msgctxt "Summary: Order #%1$@"
msgid "Summary: Order #%1$@"
msgstr "Resumo: pedido #%1$@"

#. Title of 'Summary' section in the receipt when the order number is unknown
msgctxt "Summary"
msgid "Summary"
msgstr "Resumo"

#. Error message when the card reader service experiences an unexpected
#. internal service error.
msgctxt "Sorry, this payment couldn’t be processed"
msgid "Sorry, this payment couldn’t be processed"
msgstr "Não foi possível processar este pagamento"

#. Message from the in-person payment card reader prompting user to retry
#. payment with their card
msgctxt "Retry Card"
msgid "Retry Card"
msgstr "Tente o cartão novamente"

#. Text for the button to remove a fee from the order during order creation
msgctxt "Remove Fee from Order"
msgid "Remove Fee from Order"
msgstr "Remover taxa do pedido"

#. Message from the in-person payment card reader prompting user to remove
#. their card
msgctxt "Remove Card"
msgid "Remove Card"
msgstr "Remova o cartão"

#. Message when payment is declined for a non specific reason.
msgctxt "Payment was declined for an unspecified reason. Try another means of payment."
msgid "Payment was declined for an unspecified reason. Try another means of payment."
msgstr "Pagamento recusado por motivo não especificado. Tente outro meio de pagamento"

#. Message when we don't know exactly why the payment was declined.
msgctxt "Payment was declined for an unknown reason. Try another means of payment."
msgid "Payment was declined for an unknown reason. Try another means of payment."
msgstr "Pagamento recusado por motivos desconhecidos. Tente outro meio de pagamento"

#. Message when the presented card remaining credit or balance is insufficient
#. for the purchase.
msgctxt "Payment declined due to insufficient funds. Try another means of payment."
msgid "Payment declined due to insufficient funds. Try another means of payment."
msgstr "Pagamento recusado por saldo insuficiente Tente outro meio de pagamento"

#. Title of order note section in the receipt, commonly used for Quick Orders.
msgctxt "Notes"
msgid "Notes"
msgstr "Anotações"

#. The title on the placeholder overlay when there are no coupons on the coupon
#. list screen.
msgctxt "No coupons found"
msgid "No coupons found"
msgstr "Nenhum cupom encontrado"

#. Error message when there is no connection to the Internet.
msgctxt "No connection to the Internet - please connect to the Internet and try again."
