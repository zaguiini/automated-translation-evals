#. Title of the Push Notifications Benefits View when WooCommerce plugin is
#. outdated
msgctxt "wpcomPushNotificationsBenefitsViewModel.updatePluginTitle"
msgid "Get push notifications for your store"
msgstr "Receba notificações por push para sua loja"

#. Description text on the Push Notifications Benefits View when WooCommerce
#. plugin is outdated
msgctxt "wpcomPushNotificationsBenefitsViewModel.updatePluginDescription"
msgid "Your store is already connected to a WordPress.com account, but you’ll need to update WooCommerce plugin to enable push notifications for new orders, reviews, and more."
msgstr "Sua loja já está conectada a uma conta do WordPress.com, mas você precisará atualizar o plugin do WooCommerce para ativar as notificações por push para novos pedidos, avaliações e muito mais."

#. Title for the WPCom connection setup screen when the site is already
#. connected to WordPress.com.
msgctxt "wpComConnectionSetupViewModel.titleSetUpPushNotifications"
msgid "Set up push notifications"
msgstr "Configurar notificações por push"

#. Title for the WPCom connection setup screen when the site is not yet
#. connected.
msgctxt "wpComConnectionSetupViewModel.titleConnectToWordPressCom"
msgid "Connect to WordPress.com"
msgstr "Conectar ao WordPress.com"

#. Accessibility label for the copy phone button in booking details.
msgctxt "pos.bookingDetailView.copyPhone.accessibilityLabel"
msgid "Copy phone number"
msgstr "Copiar número de telefone"

#. Note added to order when Scan to Pay is used.
msgctxt "paymentMethods.scanToPayNoteText.note"
msgid "Payment link shared via Scan to Pay. Please verify payment before fulfilling order."
msgstr "Link de pagamento compartilhado via Escaneie para pagar. Verifique o pagamento antes de atender ao pedido."

#. Title of the Connect WPCom card on My Store screen
msgctxt "connectWPComCard.title"
msgid "Never miss a new order"
msgstr "Nunca perca um novo pedido"

#. Subtitle of the Connect WPCom card on My Store screen
msgctxt "connectWPComCard.subtitle"
msgid "Enable push notifications to stay on top of new orders and reviews."
msgstr "Ative as notificações por push para ficar por dentro de novos pedidos e avaliações."

#. Button to hide the Connect WPCom card from the My Store screen
msgctxt "connectWPComCard.hideButton"
msgid "Hide this content"
msgstr "Ocultar este conteúdo"

#. Title for 'Refund' button in payment section in booking details view.
msgctxt "BookingDetailsView.payment.refund.title"
msgid "Refund"
msgstr "Reembolso"

#. Error message in the Push Notifications Benefits View for users without
#. admin role
msgctxt "wpcomPushNotificationsBenefitsViewModel.variantCheckError.noPermission"
msgid "Your account does not have permission to complete push notifications setup. Please ask your store administrator to handle this."
msgstr "Sua conta não tem permissão para concluir a configuração de notificações por push. Peça ao administrador da sua loja para resolver isso."

#. Generic error message in the Push Notifications Benefits View
msgctxt "wpcomPushNotificationsBenefitsViewModel.variantCheckError.generic"
msgid "We could not complete the push notifications setup. Please contact support for assistance."
msgstr "Não foi possível concluir a configuração de notificações por push. Entre em contato com o suporte para obter ajuda."

#. The terms to be agreed upon when tapping the Continue button on the Push
#. Notifications Benefits View.
msgctxt "wpcomPushNotificationsBenefitsViewModel.termsOfService"
msgid "Terms of Service"
msgstr "Termos de serviço"

#. Content of the label at the end of the Wrong Account screen. Reads like: By
#. continuing, you agree to our Terms of Service and to share details with
#. WordPress.com.
msgctxt "wpcomPushNotificationsBenefitsViewModel.termsContent"
msgid "By continuing, you agree to our %1$@ and to %2$@ with WordPress.com."
msgstr "Ao continuar, você concorda com nossos %1$@ e %2$@ com o WordPress.com."

#. The action to be agreed upon when tapping the Continue button on the Push
#. Notifications Benefits View.
msgctxt "wpcomPushNotificationsBenefitsViewModel.shareDetails"
msgid "share details"
msgstr "compartilhar detalhes"

#. Button title to update the WooCommerce plugin in the Push Notifications
#. Benefits View
msgctxt "wpcomPushNotificationsBenefitsView.updatePluginButton"
msgid "Update plugin"
msgstr "Atualizar plugin"

#. Title of the error state in the Push Notifications Benefits View
msgctxt "wpcomPushNotificationsBenefitsView.errorTitle"
msgid "Something went wrong"
msgstr "Ocorreu um erro"

#. Button title to contact support in the Push Notifications Benefits View
msgctxt "wpcomPushNotificationsBenefitsView.contactSupport"
msgid "Contact support"
msgstr "Fale com o suporte"

#. Get help button title in the WPCom connection setup screen toolbar.
msgctxt "wpComConnectionSetupView.getHelpButton"
msgid "Get help"
msgstr "Obter ajuda"

#. Error message when the WooCommerce plugin version is outdated. %@ is the
#. current plugin version.
msgctxt "wpComConnectionSetupStepView.outdatedPlugin"
msgid "Your current WooCommerce plugin version %1$@ needs updating to fully connect your store to WordPress.com."
msgstr "A versão atual do seu plugin WooCommerce %1$@ precisa ser atualizada para conectar completamente sua loja ao WordPress.com."

#. Error message when push notification registration fails during setup
msgctxt "wpcomConnectionSetupHandler.PushStep.genericError"
msgid "There was an error enabling push notifications. Please try again or contact support if this error continues."
msgstr "Ocorreu um erro ao ativar as notificações por push. Tente novamente ou entre em contato com o suporte se o erro persistir."

#. Generic error message when the plugin check step fails during push
#. notification setup
msgctxt "wpcomConnectionSetupHandler.PluginCheckStep.genericError"
msgid "There was an error checking the version of WooCommerce plugin on your store. Please try again or contact support if this error continues."
msgstr "Ocorreu um erro ao verificar a versão do plugin WooCommerce na sua loja. Tente novamente ou entre em contato com o suporte se o erro persistir."

#. Generic error message when the connection step fails during push
#. notification setup
msgctxt "wpcomConnectionSetupHandler.ConnectionStep.genericError"
msgid "There was an error completing your request. Please try again or contact support if this error continues."
msgstr "Ocorreu um erro ao concluir sua solicitação. Tente novamente ou entre em contato com o suporte se o erro persistir."

#. Error message when the connection step is canceled during push notification
#. setup
msgctxt "wpcomConnectionSetupHandler.ConnectionStep.canceled"
msgid "Connection canceled."
msgstr "Conexão cancelada."

#. Title of the web view to update WooCommerce plugin during push notification
#. setup
msgctxt "wooPushNotificationSetupCoordinator.updateWooCommerce"
msgid "Update WooCommerce"
msgstr "Atualizar WooCommerce"

