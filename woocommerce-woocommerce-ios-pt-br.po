#. Error message when the reader's IP address is unknown.
msgctxt "hardware.cardReader.underlyingError.unknownReaderIpAddress"
msgid "The reader returned from discovery does not have an IP address and cannot be connected to."
msgstr "O leitor que a descoberta retornou não tem um endereço de IP e não pode ser conectado."

#. Error message when an unexpected error occurs with the reader.
msgctxt "hardware.cardReader.underlyingError.unexpectedReaderError"
msgid "An unexpected error occurred with the reader."
msgstr "Ocorreu um erro inesperado com o leitor."

#. Error message when there is an error decoding the Stripe API response.
msgctxt "hardware.cardReader.underlyingError.stripeAPIResponseDecodingError"
msgid "Please contact support - there was an error decoding the Stripe API response."
msgstr "Entre em contato com o suporte. Ocorreu um erro ao decodificar a resposta da Stripe API."

#. Error message when the refund operation failed.
msgctxt "hardware.cardReader.underlyingError.refundFailed"
msgid "The refund failed. The customer’s bank or card issuer was unable to process it correctly (e.g., a closed bank account or a problem with the card)."
msgstr "Falha no reembolso. O banco ou emissor do cartão do cliente não conseguiu fazer o processamento corretamente (por exemplo, conta bancária encerrada ou problema com o cartão)."

#. Error message when the reader tipping parameter is invalid.
msgctxt "hardware.cardReader.underlyingError.readerTippingParameterInvalid"
msgid "Please contact support - the reader tipping parameter is invalid."
msgstr "Entre em contato com o suporte: o parâmetro de gorjeta do leitor é inválido."

#. Error message when the reader software update fails due to an expired
#. update.
msgctxt "hardware.cardReader.underlyingError.readerSoftwareUpdateFailedExpiredUpdate"
msgid "Updating the reader software failed because the update has expired. Please disconnect and reconnect from the reader to retrieve a new update."
msgstr "Falha ao atualizar o software do leitor porque a atualização expirou. Conecte-se novamente ao leitor para realizar uma nova atualização."

#. Error message when the reader is missing encryption keys.
msgctxt "hardware.cardReader.underlyingError.readerMissingEncryptionKeys"
msgid "The reader is missing encryption keys required for taking payments and has disconnected and rebooted. Reconnect to the reader to attempt to re-install the keys. If the error persists, please contact support."
msgstr "O leitor está sem as chaves de criptografia necessárias para receber pagamentos e foi desconectado e reinicializado. Conecte-se novamente ao leitor para tentar reinstalar as chaves. Se o problema continuar, entre em contato com o suporte."

#. Error message when the reader connection configuration is invalid.
msgctxt "hardware.cardReader.underlyingError.readerConnectionConfigurationInvalid"
msgid "The reader connection configuration is invalid."
msgstr "A configuração de conexão do leitor é inválida."

#. Error message when online PIN is not supported in offline mode.
msgctxt "hardware.cardReader.underlyingError.onlinePinNotSupportedOffline"
msgid "Online PIN is not supported in offline mode. Please retry the payment with another card."
msgstr "O PIN online não é compatível com o modo offline. Tente fazer o pagamento de novo com outro cartão."

#. Error message when the offline transaction was declined.
msgctxt "hardware.cardReader.underlyingError.offlineTransactionDeclined"
msgid "Confirming a payment while offline and the card’s verification failed."
msgstr "A confirmação offline de pagamento e a verificação do cartão falharam."

#. Error message when a test card is used in live mode while offline.
msgctxt "hardware.cardReader.underlyingError.offlineTestCardInLivemode"
msgid "A test card is used in live mode while offline."
msgstr "Um cartão de teste é usado no modo ativo quando offline."

#. Error message when there is a mismatch between offline collect and confirm.
msgctxt "hardware.cardReader.underlyingError.offlineCollectAndConfirmMismatch"
msgid "Please ensure the network connection is consistent at payment collection and confirmation."
msgstr "Verifique se a conexão de rede é consistente durante o recebimento e confirmação do pagamento."

#. Error message when the card is expired and offline mode is active.
msgctxt "hardware.cardReader.underlyingError.offlineAndCardExpired"
msgid "Confirming a payment while offline and the card was identified as being expired."
msgstr "A confirmação offline de pagamento e o cartão foram identificados como expirados."

#. Error message when the setup intent is missing.
msgctxt "hardware.cardReader.underlyingError.nilSetupIntent"
msgid "Please contact support - the setup intent is missing."
msgstr "Entre em contato com o suporte: o intent da configuração está faltando."

#. Error message when the refund payment method is missing.
msgctxt "hardware.cardReader.underlyingError.nilRefundPaymentMethod"
msgid "Please contact support - the refund payment method is missing."
msgstr "Entre em contato com o suporte: o método de pagamento de reembolso está faltando."

#. Error message when the payment intent is missing.
msgctxt "hardware.cardReader.underlyingError.nilPaymentIntent"
msgid "Please contact support - the payment intent is missing."
msgstr "Entre em contato com o suporte: o intent de pagamento está faltando."

#. Error message when EMV data is missing.
msgctxt "hardware.cardReader.underlyingError.missingEMVData"
msgid "The reader failed to read the data from the presented payment method. If you encounter this error repeatedly, the reader may be faulty and please contact support."
msgstr "O leitor não conseguiu ler os dados do método de pagamento fornecido. Se este erro acontecer várias vezes, o leitor poderá estar com uma falha. Nesse caso, entre em contato com o suporte."

#. Error message when a required parameter is invalid.
msgctxt "hardware.cardReader.underlyingError.invalidRequiredParameter"
msgid "Please contact support - a required parameter is invalid."
msgstr "Entre em contato com o suporte: um parâmetro obrigatório é inválido."

#. Error message when the refund parameters are invalid.
msgctxt "hardware.cardReader.underlyingError.invalidRefundParameters"
msgid "Please contact support - the refund parameters are invalid."
msgstr "Entre em contato com o suporte: os parâmetros de reembolso são inválidos."

#. Error message when the reader for update is invalid.
msgctxt "hardware.cardReader.underlyingError.invalidReaderForUpdate"
msgid "The reader for update is invalid."
msgstr "O leitor da atualização é inválido."

#. Error message when the location ID parameter is invalid.
msgctxt "hardware.cardReader.underlyingError.invalidLocationIdParameter"
msgid "The location ID is invalid."
msgstr "A ID de localização é inválida."

#. Error message when the discovery configuration is invalid.
msgctxt "hardware.cardReader.underlyingError.invalidDiscoveryConfiguration"
msgid "Please contact support - the discovery configuration is invalid."
msgstr "Entre em contato com o suporte: a configuração de descoberta é inválida."

#. Error message when the client secret is invalid.
msgctxt "hardware.cardReader.underlyingError.invalidClientSecret"
msgid "Please contact support - the client secret is invalid."
msgstr "Entre em contato com o suporte: a chave secreta do cliente é inválida."

#. Error message when the internet connection operation timed out.
msgctxt "hardware.cardReader.underlyingError.internetConnectTimeOut"
msgid "Connecting to reader over the internet timed out. Make sure your device and reader are on the same Wifi network and your reader is connected to the Wifi network."
msgstr "A conexão com o leitor pela Internet expirou. Verifique se o dispositivo e o leitor estão na mesma rede Wi-Fi e se o leitor está conectado a ela."

#. Error message when an internal network error occurs.
msgctxt "hardware.cardReader.underlyingError.internalNetworkError"
msgid "An unknown network error occurred."
msgstr "Ocorreu um erro de rede desconhecido."

#. Error message when Interac is not supported in offline mode.
msgctxt "hardware.cardReader.underlyingError.interacNotSupportedOffline"
msgid "Interac is not supported in offline mode."
msgstr "O Interac não é compatível com o modo offline."

#. Error message when forwarding a test mode payment in live mode is
#. prohibited.
msgctxt "hardware.cardReader.underlyingError.forwardingTestModePaymentInLiveMode"
msgid "Forwarding a test mode payment in live mode is prohibited."
msgstr "É proibido redirecionar um pagamento do modo de teste no modo ativo."

#. Error message when forwarding a live mode payment in test mode is
#. prohibited.
msgctxt "hardware.cardReader.underlyingError.forwardingLiveModePaymentInTestMode"
msgid "Forwarding a live mode payment in test mode is prohibited."
msgstr "É proibido redirecionar um pagamento do modo ativo no modo de teste."

#. Error message when a feature is unavailable.
msgctxt "hardware.cardReader.underlyingError.featureNotAvailable"
msgid "Please contact support - the feature is unavailable."
msgstr "Entre em contato com o suporte: a funcionalidade está indisponível."

#. Error message when the connection token provider operation times out.
msgctxt "hardware.cardReader.underlyingError.connectionTokenProviderTimedOut"
msgid "The connection token request timed out."
msgstr "O token de conexão expirou."

#. Error message when the connection token provider finishes with an error.
msgctxt "hardware.cardReader.underlyingError.connectionTokenProviderCompletedWithError"
msgid "There was an error fetching the connection token."
msgstr "Ocorreu um erro ao buscar o token de conexão."

#. Error message when the command requires cardholder consent.
msgctxt "hardware.cardReader.underlyingError.commandRequiresCardholderConsent"
msgid "The cardholder must give consent in order for this operation to succeed."
msgstr "O titular do cartão precisa dar consentimento para concluir esta operação."

#. Error message when the command is not allowed.
msgctxt "hardware.cardReader.underlyingError.commandNotAllowed"
msgid "Please contact support - the command is not allowed to execute by the operating system."
msgstr "Entre em contato com o suporte: não é permitido executar o comando pelo sistema operacional."

#. Error message when card swipe functionality is unavailable.
msgctxt "hardware.cardReader.underlyingError.cardSwipeNotAvailable"
msgid "Card swipe functionality is unavailable."
msgstr "A funcionalidade de passar o cartão está indisponível."

#. Error message when an operation cannot be canceled because it is already
#. completed.
msgctxt "hardware.cardReader.underlyingError.cancelFailedAlreadyCompleted"
msgid "The operation could not be canceled because it was already completed."
msgstr "A operação não foi cancelada porque ela já foi concluída."

#. Error message when Bluetooth reconnect has started.
msgctxt "hardware.cardReader.underlyingError.bluetoothReconnectStarted"
msgid "The Bluetooth reader has disconnected and we are attempting to reconnect."
msgstr "O leitor por Bluetooth foi desconectado, e estamos tentando conectar novamente."

#. Error message when the Bluetooth peer removed pairing information.
msgctxt "hardware.cardReader.underlyingError.bluetoothPeerRemovedPairingInformation"
msgid "The reader has removed this device pairing information. Try forgetting the reader in iOS Settings."
msgstr "O leitor removeu as informações de pareamento deste dispositivo. Esqueça o leitor nas preferências do iOS."

#. Explanation in the alert presented when the user tries to connect a
#. Bluetooth card reader with insufficient permissions
msgctxt "hardware.cardReader.underlyingError.bluetoothDenied"
msgid "This app needs permission to access Bluetooth to connect to your card reader. You can grant permission in the system's Settings app, in the Woo section."
msgstr "Este app precisa de permissão para acessar o Bluetooth e se conectar ao seu leitor de cartão. Para conceder permissão, acesse a seção do Woo no app de configurações do sistema."

#. Error message when the Bluetooth connection has an invalid location ID
#. parameter.
msgctxt "hardware.cardReader.underlyingError.bluetoothConnectionInvalidLocationIdParameter"
msgid "The Bluetooth connection has an invalid location ID."
msgstr "A conexão por Bluetooth tem uma ID de localização inválida."

#. Error message when Bluetooth is already paired with another device.
msgctxt "hardware.cardReader.underlyingError.bluetoothAlreadyPairedWithAnotherDevice"
msgid "The Bluetooth reader is already paired to another device. The reader must have its pairing reset to connect to this device."
msgstr "O leitor de Bluetooth já está pareado com outro dispositivo. Você precisa redefinir o pareamento do leitor para conectá-lo a este dispositivo."

#. Error message when the Apple built-in reader account is deactivated.
msgctxt "hardware.cardReader.underlyingError.tapToPayReaderAccountDeactivated"
msgid "The linked Apple ID account has been deactivated."
msgstr "A conta Apple vinculada foi desativada."

#. Explanation in the alert presented when the user tries to connect a
#. Bluetooth card reader with insufficient permissions
msgctxt "hardware.cardReader.cardReaderServiceError.bluetoothDenied"
msgid "This app needs permission to access Bluetooth to connect to your card reader. You can grant permission in the system's Settings app, in the Woo section."
msgstr "Este app precisa de permissão para acessar o Bluetooth e se conectar ao seu leitor de cartão. Para conceder permissão, acesse a seção do Woo no app de configurações do sistema."

