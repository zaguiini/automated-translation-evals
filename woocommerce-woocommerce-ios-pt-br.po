#. Title for the alert shown when the site info check fails but the site
#. appears to be a WordPress site.
msgctxt "siteAddress.siteInfoFailed.alert.title"
msgid "Connection Issue"
msgstr "Problema de conexão"

#. Message for the alert shown when the site info check fails but API discovery
#. finds a WordPress REST API.
msgctxt "siteAddress.siteInfoFailed.alert.message"
msgid "We couldn't verify your site details. You can try logging in with your site credentials instead."
msgstr "Não foi possível verificar os detalhes do seu site. Você pode tentar fazer login com as credenciais do seu site."

#. Button title to proceed to site credentials login when site info check
#. fails.
msgctxt "siteAddress.siteInfoFailed.alert.loginWithSiteCredentials"
msgid "Log In with Site Credentials"
msgstr "Faça login com as credenciais do site"

#. Button title to dismiss the site info failure alert.
msgctxt "siteAddress.siteInfoFailed.alert.cancel"
msgid "Cancel"
msgstr "Cancelar"

#. Error message shown when the site info check and API discovery both fail.
msgctxt "siteAddress.siteConnectionError"
msgid "We're having trouble connecting to this site. Please check the site address and try again."
msgstr "Não foi possível conectar a este site. Verifique o endereço do site e tente novamente."

#. PermissionKit description shown for a manual significant
#. change.manualChangeID: %1$@ is a short description.
msgctxt "significantChangeConsent.manual.description"
msgid "Significant app update: %1$@."
msgstr "Atualização significativa do aplicativo: %1$@."

#. PermissionKit description shown when the app age rating changes.ratingCode:
#. %1$d is the new rating code.
msgctxt "significantChangeConsent.ageRatingChange.description"
msgid "App age rating changed to %1$d."
msgstr "Classificação etária do aplicativo alterada para %1$d."

#. Secondary not now button in the What's New screen
msgctxt "reportList.notNow.button"
